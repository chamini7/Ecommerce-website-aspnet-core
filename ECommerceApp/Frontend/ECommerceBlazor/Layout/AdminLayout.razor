@inherits LayoutComponentBase
@inject NavigationManager Nav

<div class="page">
    <NavMenu />
    <div class="admin-shell">
        <aside class="admin-sidebar">
            <div class="sidebar-title">⚙️ Admin Panel</div>
            <a href="/admin/products" class="@(IsActive("/admin/products") ? "active" : "")">📦 Products</a>
            <a href="/admin/orders" class="@(IsActive("/admin/orders") ? "active" : "")">🧾 Orders</a>
            <a href="/" class="back-link">← Back to Store</a>
        </aside>
        <main class="admin-content">
            @Body
        </main>
    </div>
    <Footer />
</div>

@code {
    private bool IsActive(string path) => Nav.Uri.EndsWith(path);
}
