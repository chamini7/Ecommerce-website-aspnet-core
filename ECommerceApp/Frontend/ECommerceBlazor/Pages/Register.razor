@page "/register"
@inject ApiService Api
@inject AuthStateService AuthState
@inject NavigationManager Nav

<div class="auth-split">
    <div class="auth-panel">
        <div class="auth-icon">⚡</div>
        <h2>Join Nexora Tech</h2>
        <p>Create your free account and unlock a smarter way to shop for laptops, keyboards, mice, chargers and more.</p>
        <ul>
            <li>✅ Save items to your Wishlist</li>
            <li>✅ Track every order in real time</li>
            <li>✅ Rate &amp; review your favorite products</li>
        </ul>
    </div>

    <div class="auth-form-side">
        <h1 class="page-title" style="margin-top:0;"><span class="emoji">📝</span>Register</h1>

        <EditForm Model="model" OnValidSubmit="HandleRegister">
            <DataAnnotationsValidator />
            <div class="form-group">
                <label>Full Name</label>
                <InputText @bind-Value="model.FullName" placeholder="Your name" />
            </div>
            <div class="form-group">
                <label>Email</label>
                <InputText @bind-Value="model.Email" placeholder="you@example.com" />
            </div>
            <div class="form-group">
                <label>Password</label>
                <div class="password-wrapper">
                    <InputText type="@(showPassword ? "text" : "password")" @bind-Value="model.Password" placeholder="••••••••" />
                    <button type="button" class="password-toggle" @onclick="() => showPassword = !showPassword" tabindex="-1">
                        @(showPassword ? "🙈" : "👁️")
                    </button>
                </div>
            </div>
            <button type="submit" class="btn btn-primary btn-block">Create Account</button>
        </EditForm>

        @if (!string.IsNullOrEmpty(error))
        {
            <p class="error">@error</p>
        }

        <p style="text-align:center; margin-top:1.2rem; font-size:0.9rem; color:var(--text-muted);">
            Already have an account? <a href="/login" style="color:var(--brand-orange); font-weight:700;">Login</a>
        </p>
    </div>
</div>

@code {
    private RegisterModel model = new();
    private string error = "";
    private bool showPassword = false;

    public class RegisterModel
    {
        public string FullName { get; set; } = "";
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
    }

    private async Task HandleRegister()
    {
        var result = await Api.RegisterAsync(model.FullName, model.Email, model.Password);
        if (result == null)
        {
            error = "Registration failed. Try a different email.";
            return;
        }

        await AuthState.LoginAsync(result.Token, result.FullName, result.Role);
        Nav.NavigateTo("/");
    }
}
