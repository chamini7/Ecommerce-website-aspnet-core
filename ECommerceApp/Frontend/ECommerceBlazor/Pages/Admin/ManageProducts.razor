@page "/admin/products"
@layout ECommerceBlazor.Layout.AdminLayout
@inject ApiService Api
@inject AuthStateService AuthState
@inject NavigationManager Nav

<h1 class="page-title"><span class="emoji">📦</span>Manage Products</h1>

@if (!AuthState.IsAdmin)
{
    <div class="card empty-state">
        <span class="emoji">🚫</span>
        Admins only. Please <a href="/login" style="color:var(--brand-orange); font-weight:700;">login</a> with an admin account.
    </div>
}
else
{
    <div class="stat-cards">
        <div class="stat-card">
            <div class="stat-value">@(products?.Count ?? 0)</div>
            <div class="stat-label">Total Products</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">@(products?.Count(p => p.StockQuantity == 0) ?? 0)</div>
            <div class="stat-label">Out of Stock</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">@(products?.Count(p => p.StockQuantity > 0 && p.StockQuantity <= 10) ?? 0)</div>
            <div class="stat-label">Low Stock</div>
        </div>
    </div>

    <button class="btn btn-primary" style="margin-bottom:1rem;" @onclick="OpenNewForm">➕ Add New Product</button>

    @if (showForm)
    {
        <div class="card" style="margin-bottom:1.5rem;">
            <h3 style="margin-top:0;">@(editingId == null ? "Add Product" : "Edit Product")</h3>
            <div class="form-group"><label>Name</label><input @bind="form.Name" /></div>
            <div class="form-group"><label>Description</label><input @bind="form.Description" /></div>
            <div class="form-group"><label>Category</label><input @bind="form.Category" placeholder="Laptops, Keyboards, Mouses, Laptop Chargers, Headphones" /></div>
            <div class="form-group"><label>Price (Rs.)</label><input type="number" @bind="form.Price" /></div>
            <div class="form-group"><label>Stock Quantity</label><input type="number" @bind="form.StockQuantity" /></div>
            <div class="form-group"><label>Image URL</label><input @bind="form.ImageUrl" placeholder="https://..." /></div>
            <div style="display:flex; gap:0.6rem;">
                <button class="btn btn-primary" @onclick="SaveProduct">💾 Save</button>
                <button class="btn btn-outline" style="color:var(--brand-navy); border-color:#ccc;" @onclick="() => showForm = false">Cancel</button>
            </div>
            @if (!string.IsNullOrEmpty(formError))
            {
                <p class="error">@formError</p>
            }
        </div>
    }

    @if (products == null)
    {
        <p>Loading products...</p>
    }
    else
    {
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Image</th><th>Name</th><th>Category</th><th>Price</th><th>Stock</th><th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in products)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(p.ImageUrl))
                            {
                                <img class="thumb" src="@p.ImageUrl" />
                            }
                            else
                            {
                                <span>📦</span>
                            }
                        </td>
                        <td>@p.Name</td>
                        <td>@p.Category</td>
                        <td>Rs. @p.Price.ToString("N2")</td>
                        <td>@p.StockQuantity</td>
                        <td class="action-cell">
                            <button class="btn btn-outline btn-sm" style="color:var(--brand-navy); border-color:#ccc;" @onclick="() => EditProduct(p)">✏️ Edit</button>
                            <button class="btn btn-danger btn-sm" @onclick="() => DeleteProduct(p.Id)">🗑️ Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!string.IsNullOrEmpty(message))
    {
        <p class="message">@message</p>
    }
}

@code {
    private List<ApiService.ProductDto>? products;
    private bool showForm = false;
    private int? editingId = null;
    private string message = "";
    private string formError = "";
    private FormModel form = new();

    public class FormModel
    {
        public string Name { get; set; } = "";
        public string Description { get; set; } = "";
        public string Category { get; set; } = "";
        public decimal Price { get; set; }
        public int StockQuantity { get; set; }
        public string ImageUrl { get; set; } = "";
    }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState.IsAdmin)
            await LoadProducts();
    }

    private async Task LoadProducts()
    {
        products = await Api.GetProductsAsync();
    }

    private void OpenNewForm()
    {
        editingId = null;
        form = new FormModel();
        formError = "";
        showForm = true;
    }

    private void EditProduct(ApiService.ProductDto p)
    {
        editingId = p.Id;
        form = new FormModel
        {
            Name = p.Name,
            Description = p.Description,
            Category = p.Category,
            Price = p.Price,
            StockQuantity = p.StockQuantity,
            ImageUrl = p.ImageUrl ?? ""
        };
        formError = "";
        showForm = true;
    }

    private async Task SaveProduct()
    {
        if (string.IsNullOrWhiteSpace(form.Name))
        {
            formError = "Product name is required.";
            return;
        }

        var request = new ApiService.ProductWriteRequest(form.Name, form.Description, form.Price, form.StockQuantity, form.Category, form.ImageUrl);

        var response = editingId == null
            ? await Api.CreateProductAsync(request)
            : await Api.UpdateProductAsync(editingId.Value, request);

        if (response.IsSuccessStatusCode)
        {
            message = editingId == null ? "✅ Product created!" : "✅ Product updated!";
            showForm = false;
            await LoadProducts();
        }
        else
        {
            formError = "Failed to save product. Make sure you're logged in as Admin.";
        }
    }

    private async Task DeleteProduct(int id)
    {
        var response = await Api.DeleteProductAsync(id);
        if (response.IsSuccessStatusCode)
        {
            message = "🗑️ Product deleted.";
            await LoadProducts();
        }
        else
        {
            message = "Failed to delete product.";
        }
    }
}
