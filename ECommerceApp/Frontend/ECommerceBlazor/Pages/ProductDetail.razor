@page "/product/{Id:int}"
@inject ApiService Api
@inject AuthStateService AuthState

@if (product == null)
{
    <p>Loading...</p>
}
else
{
    <div class="product-detail">
        <div class="detail-image" style="position:relative; display:flex; align-items:center; justify-content:center; font-size:5rem; background:linear-gradient(135deg,#fff4e8,#ffe4cc); overflow:hidden;">
            <span>📦</span>
            @if (!string.IsNullOrWhiteSpace(product.ImageUrl))
            {
                <img src="@product.ImageUrl" alt="@product.Name" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover;" onerror="this.style.display='none'" />
            }
        </div>

        <div>
            <span class="category-tag">@product.Category</span>
            <h1 class="page-title" style="margin-top:0.3rem;">@product.Name</h1>

            @if (reviews != null && reviews.Count > 0)
            {
                <div style="margin-bottom:0.75rem;">
                    <span class="stars">@Stars((int)Math.Round(reviewsResponse!.AverageRating))</span>
                    <span style="color:var(--text-muted); font-size:0.9rem;">@reviewsResponse.AverageRating / 5 (@reviewsResponse.Count reviews)</span>
                </div>
            }

            <p style="color:var(--text-muted);">@product.Description</p>
            <div class="price-row" style="margin:1rem 0;">
                <span class="price" style="font-size:1.6rem;">@product.Price.ToString("N2")</span>
                <span class="stock-note">@product.StockQuantity in stock</span>
            </div>

            <button class="btn btn-primary" @onclick="AddToCart" disabled="@(product.StockQuantity == 0)">🛒 Add to Cart</button>
            @if (AuthState.IsLoggedIn)
            {
                <button class="btn btn-outline" style="color:var(--brand-red); border-color:var(--brand-red); margin-left:0.5rem;" @onclick="ToggleWishlist">
                    @(isWishlisted ? "♥ Saved" : "♡ Save for later")
                </button>
            }

            @if (!string.IsNullOrEmpty(message))
            {
                <p class="message">@message</p>
            }
        </div>
    </div>

    <div class="card">
        <h3 style="margin-top:0;">⭐ Reviews</h3>

        @if (AuthState.IsLoggedIn)
        {
            <div style="margin-bottom:1.5rem;">
                <label style="font-weight:600; font-size:0.88rem; color:var(--brand-navy); display:block; margin-bottom:0.4rem;">Your Rating</label>
                <div class="star-picker" style="margin-bottom:0.75rem;">
                    @for (int i = 1; i <= 5; i++)
                    {
                        var starValue = i;
                        <span class="@(starValue <= newRating ? "filled" : "")" @onclick="() => newRating = starValue">★</span>
                    }
                </div>
                <div class="form-group">
                    <input @bind="newComment" placeholder="Share your thoughts about this product..." />
                </div>
                <button class="btn btn-primary btn-sm" @onclick="SubmitReview">Submit Review</button>
            </div>
        }

        @if (reviews == null)
        {
            <p>Loading reviews...</p>
        }
        else if (!reviews.Any())
        {
            <p style="color:var(--text-muted);">No reviews yet. Be the first to review this product!</p>
        }
        else
        {
            @foreach (var r in reviews)
            {
                <div class="review-item">
                    <div style="display:flex; justify-content:space-between;">
                        <strong>@r.UserName</strong>
                        <span class="stars">@Stars(r.Rating)</span>
                    </div>
                    <p style="margin:0.3rem 0 0 0; color:var(--text-muted);">@r.Comment</p>
                    <span style="font-size:0.75rem; color:#aaa;">@r.CreatedAt.ToString("MMM dd, yyyy")</span>
                </div>
            }
        }
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private ApiService.ProductDto? product;
    private List<ApiService.ReviewDto>? reviews;
    private ApiService.ReviewsResponse? reviewsResponse;
    private string message = "";
    private int newRating = 5;
    private string newComment = "";
    private bool isWishlisted = false;

    protected override async Task OnInitializedAsync()
    {
        product = await Api.GetProductAsync(Id);
        await LoadReviews();

        if (AuthState.IsLoggedIn)
        {
            var wishlist = await Api.GetWishlistAsync();
            isWishlisted = wishlist?.Any(w => w.ProductId == Id) ?? false;
        }
    }

    private async Task ToggleWishlist()
    {
        if (isWishlisted)
        {
            var response = await Api.RemoveFromWishlistAsync(Id);
            if (response.IsSuccessStatusCode) isWishlisted = false;
        }
        else
        {
            var response = await Api.AddToWishlistAsync(Id);
            if (response.IsSuccessStatusCode) isWishlisted = true;
        }
    }

    private async Task LoadReviews()
    {
        reviewsResponse = await Api.GetReviewsAsync(Id);
        reviews = reviewsResponse?.Reviews;
    }

    private async Task AddToCart()
    {
        var response = await Api.AddToCartAsync(Id, 1);
        message = response.IsSuccessStatusCode ? "✅ Added to cart!" : "❌ Could not add to cart.";
    }

    private async Task SubmitReview()
    {
        if (string.IsNullOrWhiteSpace(newComment)) return;

        var response = await Api.AddReviewAsync(Id, newRating, newComment);
        if (response.IsSuccessStatusCode)
        {
            newComment = "";
            newRating = 5;
            await LoadReviews();
        }
    }

    private string Stars(int rating) => new string('★', rating) + new string('☆', 5 - rating);
}
