@page "/profile"
@inject ApiService Api
@inject AuthStateService AuthState

<h1 class="page-title"><span class="emoji">👤</span>My Profile</h1>

@if (!AuthState.IsLoggedIn)
{
    <div class="card card-narrow empty-state">
        <span class="emoji">🔒</span>
        Please <a href="/login" style="color:var(--brand-orange); font-weight:700;">login</a> to view your profile.
    </div>
}
else if (profile == null)
{
    <p>Loading profile...</p>
}
else
{
    <div style="display:flex; gap:1.5rem; flex-wrap:wrap;">
        <div class="card" style="flex:1; min-width:300px;">
            <h3 style="margin-top:0;">Edit Profile</h3>
            <div class="form-group">
                <label>Full Name</label>
                <input @bind="fullName" />
            </div>
            <div class="form-group">
                <label>Email</label>
                <input value="@profile.Email" disabled style="background:#f5f5f5; color:#999;" />
            </div>
            <div class="form-group">
                <label>Address</label>
                <input @bind="address" placeholder="Your delivery address" />
            </div>
            <div class="form-group">
                <label>Phone Number</label>
                <input @bind="phone" placeholder="07XXXXXXXX" />
            </div>
            <button class="btn btn-primary" @onclick="SaveProfile">💾 Save Changes</button>
            @if (!string.IsNullOrEmpty(profileMessage))
            {
                <p class="@(profileError ? "error" : "message")">@profileMessage</p>
            }
        </div>

        <div class="card" style="flex:1; min-width:300px;">
            <h3 style="margin-top:0;">Change Password</h3>
            <div class="form-group">
                <label>Current Password</label>
                <div class="password-wrapper">
                    <input type="@(showPw ? "text" : "password")" @bind="currentPassword" />
                    <button type="button" class="password-toggle" @onclick="() => showPw = !showPw" tabindex="-1">@(showPw ? "🙈" : "👁️")</button>
                </div>
            </div>
            <div class="form-group">
                <label>New Password</label>
                <div class="password-wrapper">
                    <input type="@(showPw ? "text" : "password")" @bind="newPassword" />
                    <button type="button" class="password-toggle" @onclick="() => showPw = !showPw" tabindex="-1">@(showPw ? "🙈" : "👁️")</button>
                </div>
            </div>
            <button class="btn btn-primary" @onclick="ChangePassword">🔒 Update Password</button>
            @if (!string.IsNullOrEmpty(pwMessage))
            {
                <p class="@(pwError ? "error" : "message")">@pwMessage</p>
            }
        </div>
    </div>
}

@code {
    private ApiService.ProfileDto? profile;
    private string fullName = "";
    private string address = "";
    private string phone = "";
    private string profileMessage = "";
    private bool profileError;

    private string currentPassword = "";
    private string newPassword = "";
    private string pwMessage = "";
    private bool pwError;
    private bool showPw = false;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState.IsLoggedIn)
        {
            profile = await Api.GetProfileAsync();
            if (profile != null)
            {
                fullName = profile.FullName;
                address = profile.Address ?? "";
                phone = profile.PhoneNumber ?? "";
            }
        }
    }

    private async Task SaveProfile()
    {
        var response = await Api.UpdateProfileAsync(fullName, address, phone);
        profileError = !response.IsSuccessStatusCode;
        profileMessage = response.IsSuccessStatusCode ? "✅ Profile updated!" : "Failed to update profile.";
    }

    private async Task ChangePassword()
    {
        if (string.IsNullOrWhiteSpace(currentPassword) || string.IsNullOrWhiteSpace(newPassword))
        {
            pwError = true;
            pwMessage = "Please fill in both password fields.";
            return;
        }

        var response = await Api.ChangePasswordAsync(currentPassword, newPassword);
        pwError = !response.IsSuccessStatusCode;
        pwMessage = response.IsSuccessStatusCode ? "✅ Password changed!" : "Failed to change password. Check your current password.";
        if (response.IsSuccessStatusCode)
        {
            currentPassword = "";
            newPassword = "";
        }
    }
}
